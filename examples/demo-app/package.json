{
  "name": "@democraft/example-demo-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "start": "tsx src/server.ts",
    "inspect": "democraft inspect src/demo.ts",
    "targets": "democraft targets src/demo.ts --json",
    "validate": "democraft validate src/demo.ts",
    "capture": "democraft capture src/demo.ts",
    "validate:private": "democraft validate src/private-demo.ts",
    "capture:private": "democraft capture src/private-demo.ts",
    "timeline": "democraft timeline src/demo.ts --manifest .democraft/runs/create-project-live/manifest.json -o .democraft/timelines/create-project-live.landscape.json",
    "preview": "democraft preview --manifest .democraft/runs/create-project-live/manifest.json --timeline .democraft/timelines/create-project-live.landscape.json -o .democraft/previews/create-project-live.html",
    "render": "democraft render src/demo.ts -o .democraft/renders/create-project-live.mp4"
  },
  "dependencies": {
    "@democraft/compiler": "workspace:*",
    "@democraft/core": "workspace:*",
    "@democraft/playwright": "workspace:*",
    "@democraft/timeline": "workspace:*"
  }
}
