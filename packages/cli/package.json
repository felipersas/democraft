{
  "name": "@democraft/cli",
  "version": "0.1.0-beta.1",
  "description": "Command-line interface for authoring, capturing, and rendering Democraft demos.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipersas/democraft.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/felipersas/democraft#readme",
  "bugs": "https://github.com/felipersas/democraft/issues",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "democraft": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@democraft/authentication": "workspace:*",
    "@democraft/compiler": "workspace:*",
    "@democraft/core": "workspace:*",
    "@democraft/playwright": "workspace:*",
    "@democraft/preview": "workspace:*",
    "@democraft/remotion": "workspace:*",
    "@democraft/schema": "workspace:*",
    "@democraft/studio": "workspace:*",
    "@democraft/timeline": "workspace:*",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3"
  }
}
