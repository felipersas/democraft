{
  "name": "@democraft/testing",
  "version": "0.1.0-beta.0",
  "description": "Testing fixtures and helpers for Democraft integrations.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipersas/democraft.git",
    "directory": "packages/testing"
  },
  "homepage": "https://github.com/felipersas/democraft#readme",
  "bugs": "https://github.com/felipersas/democraft/issues",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@democraft/compiler": "workspace:*",
    "@democraft/core": "workspace:*"
  }
}
