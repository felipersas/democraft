{
  "name": "@democraft/studio",
  "version": "0.1.0-beta.1",
  "description": "Local visual Studio runtime for Democraft demos.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipersas/democraft.git",
    "directory": "packages/studio"
  },
  "homepage": "https://github.com/felipersas/democraft#readme",
  "bugs": "https://github.com/felipersas/democraft/issues",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "files": [
    ".next/*.json",
    ".next/BUILD_ID",
    ".next/server",
    ".next/static"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "tsc --noEmit",
    "build:production": "next build",
    "prepack": "pnpm build:production",
    "start": "next start --hostname 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "next lint"
  },
  "dependencies": {
    "@democraft/authentication": "workspace:*",
    "@democraft/compiler": "workspace:*",
    "@democraft/core": "workspace:*",
    "@democraft/playwright": "workspace:*",
    "@democraft/remotion": "workspace:*",
    "@democraft/schema": "workspace:*",
    "@democraft/timeline": "workspace:*",
    "@remotion/player": "4.0.487",
    "@remotion/renderer": "4.0.487",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "^15.5.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.3"
  }
}
