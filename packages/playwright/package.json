{
  "name": "@democraft/playwright",
  "version": "0.1.0-beta.1",
  "description": "Playwright capture runtime for Democraft product demos.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipersas/democraft.git",
    "directory": "packages/playwright"
  },
  "homepage": "https://github.com/felipersas/democraft#readme",
  "bugs": "https://github.com/felipersas/democraft/issues",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --minWorkers=1 --maxWorkers=1"
  },
  "dependencies": {
    "@democraft/schema": "workspace:*",
    "playwright": "^1.58.2"
  }
}
