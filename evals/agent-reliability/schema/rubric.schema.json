{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://democraft.dev/schemas/agent-reliability/rubric.schema.json",
  "title": "DemoCraft Agent Reliability Rubric",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "thresholds", "rules"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimumSemanticLocatorRatio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "minimumEvaluationScore": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "maximumValidationErrors": { "type": "integer", "minimum": 0 },
        "maximumRepairRounds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "mustUseCollectionSampling": { "type": "boolean" },
        "mustRender": { "type": "boolean" },
        "mustNotUseUnsafeExploration": { "type": "boolean" }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "level", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "level": { "enum": ["must", "should"] },
          "description": { "type": "string", "minLength": 1 },
          "weight": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
