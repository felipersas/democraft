{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://democraft.dev/schemas/agent-reliability/scenario.schema.json",
  "title": "DemoCraft Agent Reliability Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "difficulty",
    "fixture",
    "promptFile",
    "rubricFile",
    "budgets",
    "expectedArtifacts"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z0-9-]+$"
    },
    "title": { "type": "string", "minLength": 1 },
    "difficulty": {
      "enum": ["basic", "intermediate", "advanced"]
    },
    "category": { "type": "string", "minLength": 1 },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "appFile",
        "healthPath",
        "resetPath",
        "baseUrlEnvironmentVariable"
      ],
      "properties": {
        "kind": { "const": "declarative-html" },
        "appFile": { "type": "string", "minLength": 1 },
        "healthPath": { "type": "string", "pattern": "^/" },
        "resetPath": { "type": "string", "pattern": "^/" },
        "baseUrlEnvironmentVariable": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "requiresAuth": { "type": "boolean" }
      }
    },
    "promptFile": { "type": "string", "minLength": 1 },
    "rubricFile": { "type": "string", "minLength": 1 },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maximumAttempts",
        "maximumRepairRounds",
        "maximumDurationMs"
      ],
      "properties": {
        "maximumAttempts": { "type": "integer", "minimum": 1, "maximum": 3 },
        "maximumRepairRounds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "maximumDurationMs": { "type": "integer", "minimum": 1000 },
        "commandTimeoutMs": { "type": "integer", "minimum": 1000 }
      }
    },
    "expectedArtifacts": {
      "type": "array",
      "items": {
        "enum": [
          "doctor",
          "discovery",
          "demoPlan",
          "demoSource",
          "validation",
          "capture",
          "draftRender",
          "sentinelFrames",
          "contactSheet",
          "finalRender",
          "result"
        ]
      },
      "uniqueItems": true
    }
  }
}
