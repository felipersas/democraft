{
  "title": "Acme Private - Dashboard",
  "auth": {
    "loginPath": "/private/login",
    "validationPath": "/private/dashboard",
    "validationSelector": "[data-testid=\"user-menu\"]"
  },
  "pages": [
    {
      "path": "/",
      "title": "Acme Private - Dashboard Discovery",
      "regions": [
        {
          "kind": "banner",
          "label": "Private top bar",
          "elements": [
            { "kind": "heading", "name": "Private dashboard" },
            { "kind": "button", "name": "User menu", "testId": "user-menu" }
          ]
        },
        {
          "kind": "main",
          "label": "Private metrics",
          "elements": [
            { "kind": "heading", "name": "Revenue intelligence" },
            {
              "kind": "button",
              "name": "Export report",
              "testId": "export-report"
            },
            {
              "kind": "button",
              "name": "Invite teammate",
              "testId": "invite-teammate"
            }
          ]
        }
      ]
    },
    {
      "path": "/private/login",
      "title": "Acme Private - Sign in",
      "regions": [
        {
          "kind": "main",
          "label": "Authentication required",
          "elements": [
            { "kind": "heading", "name": "Sign in required" },
            { "kind": "button", "name": "Sign in" }
          ]
        }
      ]
    },
    {
      "path": "/private/dashboard",
      "title": "Acme Private - Dashboard",
      "requiresAuth": true,
      "regions": [
        {
          "kind": "banner",
          "label": "Private top bar",
          "elements": [
            { "kind": "heading", "name": "Private dashboard" },
            { "kind": "button", "name": "User menu", "testId": "user-menu" }
          ]
        },
        {
          "kind": "main",
          "label": "Private metrics",
          "elements": [
            { "kind": "heading", "name": "Revenue intelligence" },
            {
              "kind": "button",
              "name": "Export report",
              "testId": "export-report"
            },
            {
              "kind": "button",
              "name": "Invite teammate",
              "testId": "invite-teammate"
            }
          ]
        }
      ]
    }
  ]
}
